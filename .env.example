# Absolute path to this repository on the Docker host (required).
SIMC_WEB_ROOT=/srv/simc-web

# Optional settings.
SIMC_WEB_PORT=8088
TZ=UTC
SIMC_IMAGE=simulationcraftorg/simc:latest
# Optional prebuilt web image. Leave unset when building locally.
# SIMC_WEB_IMAGE=ghcr.io/bromeego/simc-local-runner:latest
SIMC_TIMEOUT_SECONDS=1800
MAX_UPLOAD_MB=2
MAX_CONCURRENT_SIMS=1
REPORT_RETENTION_COUNT=100
WEB_THREADS=4

# Optional Docker limits for each SimulationCraft run.
# SIMC_CPUS=4
# SIMC_MEMORY=4g
